#!/usr/bin/env bash
# Configures localhost and facebook.com host mappings
set -euo pipefail

hosts_file="/etc/hosts"

sed -i '/localhost/ s/^127\.0\.0\.1[[:space:]]\+/127.0.0.2 /' "$hosts_file"

if grep -q 'facebook.com' "$hosts_file"; then
    sed -i '/facebook\.com/ s/^[0-9.]\+[[:space:]]\+/8.8.8.8 /' "$hosts_file"
else
    echo '8.8.8.8 facebook.com' >> "$hosts_file"
fi
